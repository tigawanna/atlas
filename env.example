# Atlas Server Configuration
# Copy to .env and modify as needed

# Tile serving
ATLAS_TILE_SOURCE=local          # "local" or "s3"
ATLAS_TILE_DIR=./test-data       # Path to PMTiles directory (local mode)
ATLAS_S3_BUCKET=                 # S3 bucket name (s3 mode)
ATLAS_S3_REGION=af-south-1      # AWS region for S3
ATLAS_S3_TILE_KEYS=ghana-basemap.pmtiles  # Comma-separated PMTiles keys in S3

# Server
ATLAS_PORT=3001                  # HTTP listen port
ATLAS_PUBLIC_URL=http://localhost:3001  # Public URL for TileJSON URLs
ATLAS_CACHE_SIZE_MB=256          # Tile LRU cache size

# Geocoding
ATLAS_GEOCODE_INDEX_DIR=./test-data/geocode-index
ATLAS_LANDMARK_PATH=./test-data/landmarks.bin
ATLAS_PLACES_PATH=./test-data/places.bin

# Search
ATLAS_SEARCH_INDEX_DIR=./test-data/search-index

# Routing
ATLAS_ROUTE_DIR=./test-data      # Directory for CH graph files
ATLAS_OSM_DIR=./data/osm         # OSM PBF directory for on-demand routing

# Auth (disabled by default)
ATLAS_AUTH_ENABLED=false
ATLAS_DYNAMODB_TABLE=atlas_api_keys
ATLAS_DYNAMODB_REGION=af-south-1
